esourcesChange:{purpose:"Change Resources",projectDetails:"To apply these changes, we will need to shut down and restart the project.",outputDetails:"To apply these changes, we will need to shut down and restart the output."},confirmScalingChange:{purpose:"Change Scaling",outputDetails:"To apply these changes, we will need to shut down and restart the output."},contactSupport:{general:{title:"Technical Support",message:"How can we help you?",subject:"Subject"},contact:"You should hear back from us within 8 business hours.",pending:"Sending your message",success:"Thank you, your message has been sent. You will hear back from us soon."},copyConnection:{title:"Copy Connection",pending:"Copying Connection",select:"Select the space to copy {connection} to",success:"Connection copied",errors:{noSpaces:"Copy connection lets you copy a connection from one space to another, but you are not a member of any other spaces that support data connections.",transferToAnotherAccount:"The selected space is in another account and you do not have permission to transfer content out of the current account. Contact an administrator of the current space's account to request permission.",createConnectionPermission:"You do not have permission to create a connection in the selected space. Contact an administrator of that space to request permission."}},copySpace:{copying:"Copying Space",prompt:{title:"Copy Space",info:{projects:"<strong>Projects:</strong> All projects shared with everyone in this space will be copied over to your new space. Private projects will not be copied.",users:"<strong>Users:</strong> The members of this space will not be copied over. The new space will start out with you as its only member."}},fields:{copyName:"Name"},copyPlaceholder:"Copy of {name}",transferContentError:{individual:"You do not have permission to copy this space to another account. Contact {accountName} to request permission.",org:"{accountName} does not allow you to copy its spaces to other accounts. 