bers:"Members",name:"Name",no:"No",ok:"OK",optional:"optional",options:"Options",or:"or",organization:"Organization",outputs:"Outputs",pageTitle:"Posit Cloud",password:"Password",participants:"Participants",payment:"Payment",permissions:"Permissions",placeholder:"---",plans:"Plans & Pricing",private:"Private",profile:"Profile",public:"Public",recipes:"Recipes",required:"required",save:"Save",search:"Search",searchClear:"Clear search",seat:"Seat",security:"Security",settings:"Settings",showDetails:"Show Details",sidebar:"Sidebar",signUp:"Sign Up",spaces:"Spaces",source:"source",status:"Current System Status",statusPage:"View details",subscribe:"Subscribe",support:"Technical Support",teach:"Teach",template:"Template",templates:"Templates",tipOfTheDay:"Tip of the Day",trash:"Trash",unlimited:"Unlimited",updated:"Updated",usage:"Usage",viewers:"Viewers",why:"Why?",yes:"Yes"},publishingDisabled:{title:"Content Unavailable",details:"Publishing on Posit Cloud has been deprecated and previously published data documents, applications, and APIs are no longer accessible.",projects:"RStudio and Jupyter code projects are unaffected by this change.",moreInfo:"For more information, please see <whatsNewLink>our message about this change</whatsNewLink>."},footer:{facebook:"Posit Software, PBC on Facebook",github:"Posit Software, PBC on GitHub",linkedin:"Posit Software, PBC on LinkedIn",instagram:"Posit Software, PBC on Instagram",terms:"Terms",status:"Status"},daysOfTheWeek:{monday:"Monday",tuesday:"Tuesday",wednesday:"Wednesday",thursday:"Thursday",friday:"Friday",saturday:"Saturday",sunday:"Sunday",dayOfTheMonth:"day of the month"},ordinals:{o1:"1st",o2:"2nd",o3:"3rd",o4:"4th",o5:"5th",o6:"6th",o7:"7th",o8:"8th",o9:"9th",o10:"10th",o11:"11th",o12:"12th",o13:"13th",o14:"14th",o15:"15th",o16:"16th",o17:"17th",o18:"18th",o19:"19th",o20:"20th",o21:"21st",o22:"22nd",o23:"23rd",o24:"24th",o25:"25th",o26:"26th",o27:"27th",o28:"28th",o29:"29th",o30:"30th",o31:"31st"},login:{loginGoogle:"Log in with Google",loginGithub:"Log in with Github"},header:{accountNav:"Account Navigation Menu",from:"from",learnNav:"Learn Navigation Menu",menu:"Menu",planNav:"Plan Navigation Menu",search_one:"1 result for {search}",search_other:"{count} results for {search}",spaceNav:"Space Navigation Menu",total:"( {total} )"},members:{loading:"Loading",getMore:"Get more",gettingMore:"Getting members",noAccess:"In this space, you do not have permission to see the list of members.",noMembers:"no members",noInvites:"no invitations",allMembers:"All Members",searchResults:'Results for "{search}"',noResults:"No results",invitations:"All Invitations",menu:{current:"Current Members",invitations:"Invitations"},invitation:{deleteInvitation:"Cancel Invitation",invitationSent:"Sent",invitationExpired:"Expired",resendInvitation:"Resend",copyInvitationLink:"Copy link",copiedInvitationLink:"Invitation link copied",admitted:"Admitted"},columnHeaders:{name:"Name",email:"Email",role:"Role",status:"Status"},access:{title:"Access",closed:{name:"Invitation required",description:"Add specific members to the space by sending invitations."},shared:{name:"Sharing link",description:"Anyone with the sharing link can access the space.",longDescription:'Anyone with the sharing link can access the space. Members will be assigned the "Initial Role" selected at the time they join the space.',defaultRole:"Initial Role",copyLink:"Copy Sharing Link",resetLink:"Reset Sharing Link",resetLinkSuccess:"Sharing link reset",copiedLink:"Sharing link copied"}},roles:{effective:"Effective role: {effectiveRole}",info:"More info about space roles",viewer:{name:"Viewer",info:"Viewers can view content shared with everyone."},contributor:{name:"Contributor",info:"Contributors can create, edit and manage their own content, and view space usage data."},moderator:{name:"Moderator",info:"Moderators can view, edit and manage all content, and view space usage data."},admin:{name:"Admin",info:"Admins can manage users, view, edit and manage all content, and view space usage data."}},permissions:{manage_space_content_access:"Can change their contents' access",manage_space_content_resources:"Can change their contents' resources",view_space_users:"Can view the members list"}},navigation:{help:"Help Menu",info:"Info Menu",learn:"Learn Menu",space:"Space Menu"},siteHome:{section1:{title:"Friction free data science",tagline:"Posit Cloud lets you access Posit’s powerful set of data science tools right in your browser – no installation or complex configuration required.",signup:"Get Started",login:"Already a User? Log In"},existingAccount:{message:'If you already have a shinyapps.io account, you can <a href="{loginURL}">log in</a> using your existing credentials.'},section2:{title:"Get to know Cloud",p1:"Do, share, teach and learn data science using the RStudio IDE or Jupyter Notebooks, directly from your browser. You can share projects with your team, class, workshop or the world. Teach or learn data science in R or Python with students or colleagues.",p2:"There’s nothing to install or maintain and no dedicated hardware or annual purchase contract is required. Individual users, instructors and students only need a browser - we handle everything else.",p3:"We will always offer a free plan for casual, individual use, and we now offer paid plans for professionals, instructors, researchers, and organizations.",guide:"Posit Cloud Guide",ourPlans:"Our Plans"},section4:{title:"Choose the right plan for you",individuals:{title:"Individuals",text:"Just starting your data science journey? If you only want to do data science occasionally, or if your usage is covered by your instructor or organization, our free plan is all you need. (Or, if you are a student and you only need more hours per month, consider our Cloud Student plan at a minimal cost.)"},professional:{title:"Professionals",text:"Our Standard Plan offers more capabilities, and is the best choice for most people. If you need more projects, shared spaces, compute hours, RAM, or CPUs than our free plan provides, this is the plan for you."},instructor:{title:"Instructors and Researchers",text:"Our advanced features are available for qualified instructors and researchers at a deep discount for instructional and academic use. We want to make it easy for you to teach and do research with Posit Cloud."},organization:{title:"Organizations",text:"If you want to enable multiple people in your organization to teach, learn, or do research and data science, we are happy to craft a custom package for you."}},footer:{posit:{link:"Go to Posit Software, PBC home",tagline:"The open source data science company"},products:{title:"Products",openSource:"Open Source",enterprise:"Enterprise",cloud:"Cloud",allProducts:"All Products"},solutions:{title:"Solutions",sagemaker:"Amazon Sagemaker",azure:"Microsoft Azure",cloud:"Posit Cloud",allSolutions:"All Solutions"},resources:{title:"Resources",blog:"Blog",cheatsheets:"Cheatsheets",videos:"Videos",champions:"Champions",hangout:"Data Science Hangout"},support:{title:"Support",documentation:"Documentation",contact:"Contact",community:"Posit Community",allSupport:"All Support",legal:"Legal Terms"},contact:{title:"Contact Us",address:"250 Northern Ave, Boston, Ma 02210",phone:"844-448-1212",email:"info@posit.co"},legal:{copyright:"Copyright © 2022 Posit Software, PBC formerly RStudio, PBC",terms:"Terms and Conditions",privacy:"Privacy Policy"}},hero:{productTitle:"Posit Cloud"}},output:{deprecated:"Publishing is deprecated on Posit Cloud, and the process to sunset this feature will begin at the end of December, 2024. At that point, this content will no longer be accessible. Posit Cloud projects are unaffected by this change. <guideLink>more info</guideLink>",metrics:{connections:{connect_count:"connections",subtitle:{"1h":"average connections per hour","1d":"average connections per day"},title:"Connections"},cpu:{subtitle:{"1h":"average CPU jiffies per hour","1d":"average CPU jiffies per day"},title:"CPU Usage",usage_in_usermode:"CPU jiffies"},memory:{subtitle:{"1h":"average GBs per hour","1d":"average GBs per day"},title:"Memory Usage",total_rss:"GBs"},range:{options:{day:"Day",month:"Month",week:"Week"},start:"Start",steps:{back:"go back one {rangeSize}",forward:"go forward one {rangeSize}"},time:"at 12:00 AM UTC",view:"View one:"},title:"Metrics",workers:{connect_procs:"workers",subtitle:{"1h":"average workers per hour","1d":"average workers per day"},title:"Workers"}},publishedFrom:"Published from: <parentLink>{parent}</parentLink> by <authorLink><author /></authorLink>",settings:{label:"Output Settings",info:{project:"Source Project"},scaling:{concurrentUsers:{title:"Concurrent Users",concurrentUsersLimit:"A maximum of {count} users may access this app concurrently with these settings.",concurrentUsersLimitNote:"Note: this limit depends significantly on the performance characteristics of your application, and may, in practice, be lower.",workers:{info:"The maximum number of workers that will be simultaneously running for this app, regardless of load.",infoLabel:"More information about max workers",allocated:"Max workers: {value}",changed:"Change max workers to {value}"},connectionsPerWorker:{info:"The maximum number of client connections allowed to an individual worker. Incoming connections which will exceed this limit are routed to a new worker or rejected.",infoLabel:"More information about max connections per worker",allocated:"Max connections per worker: {value}",changed:"Change max connections per worker to {value}"}},scalingUp:{title:"Scaling Up",workerLoadFactor:{info:"The load factor determines how lazily additional workers will be spawned to handle incoming load. The higher the setting, the higher the load required to spawn a new worker.",infoLabel:"More information about worker load factor",allocated:"Worker load factor: {value}%",changed:"Change worker load factor to {value}%"},startupTimeout:{info:"Maximum time to wait for the app to start. Increase this number if you load a lot of data or have a longer startup time.",infoLabel:"More information about startup time out",allocated:"Startup time out: {value} seconds",changed:"Change startup time out to {value} seconds"}},scalingDown:{title:"Scaling Down",instanceIdleTimeout:{info:"The time after which your idle app will be stopped.",infoLabel:"More information about instance idle time out",allocated:"Instance idle time out: {value} minutes",changed:"Change instance idle time out to {value} minutes"},workerIdleTimeout:{info:"Minimum time a worker will remain alive after it becomes idle - i.e. after is has no active connections.",infoLabel:"More information about worker idle time out",allocated:"Worker idle time out: {value} seconds",changed:"Change worker idle time out to {value} seconds"},connectionIdleTimeout:{info:"Maximum time allowed without data sent or received across a client connection. Connections reaching this idle threshold are closed.",infoLabel:"More information about connection idle time out",allocated:"Connection idle time out: {value} minutes",changed:"Change connection idle time out to {value} minutes",unlimited:"A value of 0 means connections will never time out (not recommended)."},connectionReadTimeout:{info:"Maximum number of seconds allowed without data received from a client connection. Connections reaching this idle read threshold are closed. Set this to 0 when deploying dashboards which send regular updates but have no need for interactivity.",infoLabel:"More information about connection read time out",allocated:"Connection read time out: {value} minutes",changed:"Change connection read time out to {value} minutes",unlimited:"A value of 0 means a lack of browser interaction will never cause the connection to close - this is useful when deploying dashboards which send regular updates but have no need for interactivity."}}},application:{resources:{hours:{changed:{singular:"With the changed settings, running this app for one hour will consume {hours} compute hour.",plural:"With the changed settings, running this app for one hour will consume {hours} compute hours."},unchanged:{singular:"Running this app for one hour will consume {hours} compute hour.",plural:"Running this app for one hour will consume {hours} compute hours."}}}},job_spec:{resources:{execution:"Execution Limit",hours:{info:"Refreshing or re-publishing this output triggers a job that consumes compute hours when it runs.",singular:"With these settings, this job would consume {hours} compute hour if it ran for one hour.",plural:"With these settings, this job would consume {hours} compute hours if it ran for one hour."}}}},type:{bokehApp:"Bokeh App",dashApp:"Dash App",document:"Document",fastAPI:"Fast API",flaskApp:"Flask App",plot:"Plot",plumber:"Plumber API",quartoDoc:"Quarto Doc",rMarkdown:"R Markdown Document",shinyApp:"Shiny App",site:"Site",streamlitApp:"Streamlit App"}},projects:{assignments:{assignment:"Assignment",continue:"Continue",start:"Start"},child:"View {count} derived project ...",childCount:"{total} derived project",children:"View {count} derived projects ...",childrenCount:"{total} derived projects",derived_one:"1 derived project",derived_other:"{count} derived projects",derivedFrom:"Derived from: <parentLink>{parent}</parentLink> by <authorLink><author /></authorLink>",derivedFromOld:"Derived from: {project} by {author}",filters:{access:{all:"All Access Levels",label:"Access",public:{space:"Space Members",cloud:"All Posit Cloud Users"},private:"Private",title:"Filter by Access"},type:{label:"Type",options:{all:"All Types",content:"Content",ide:"RStudio Projects",jupyter:"Jupyter Projects"},title:"Filter by Type"}},filteredTitle:{all:"All {scope} {type}",scope:{public:"Shared",private:"Private"},yours:"Your {scope} {type}"},getMore:"Get more content",header:{ram:"RAM",temporary:"Temporary<br>Copy"},loading:"Getting content",maintenance:{message:"Posit Cloud is currently undergoing maintenance, and cannot open or create new content at this time.",status:'Please see <a href="https://status.posit.co/">https://status.posit.co/</a> for more information.',statusInterpolated:"Please see <statusLink>https://status.posit.co/</statusLink> for more information."},menu:{all:"All",yours:"Yours"},navigation:{custom:"Custom List",main:"Content List"},newFromGithub:"New Project from Git Repository",newJupyterProject:"New Jupyter Project",newProject:"New Project",newProjectFromTemplate:"New Project from Template",newRStudioProject:"New RStudio Project",openSource:"Source Code",outputs:{many:"{total} outputs",one:"{total} output"},outputs_one:"1 output",outputs_other:"{count} outputs",privateProject:"Private",search:"Search Content",searchByNameOrDescription:"by name or description",searchDescription:'Results for "{search}" in {searchLocation}',settings:"Settings for {contentName}",sidebar:{all:"All Content",archive:"Archive",templates:"Templates",trash:"Trash",yours:"Your Content"},sort:{created_time:"Created Date",custom_order:"Custom Order",label:"Sort",name:"Name",options:{name_asc:"By name",created_time_desc:"By date created"},title:"Sort by"},title:{all:{all:"All Content",yours:"Your Content"},private:{all:"All Private Content",yours:"Your Private Content"},public:{all:"All Shared Content",yours:"Your Shared Content"}},unnamed:"Unnamed Project",visibility:{cloud:"All Posit Cloud Users",private:"Private",space:"Space members"}},project:{untitledTooltip:"Click to name your project",settings:{access:{assignment:{error:{unauthorized:"You do not have permission to change the default template in this space. Please contact a space administrator to change this project to an assignment."},header:"Assignments",info:{access:"Whenever a contributor in the space opens an assignment, they get their own permanent copy of the project to work in. If they access the assignment again later, they will always be taken back to their own copy.",label:"More info about assignments",lede:"Want to make it easier and less error prone for space members to get their own copy of this project? Make it an assignment.",sharing:"This means you can distribute a link to the project, and know that each contributor will access their own copy of the project whenever they follow it."},label:"Make this project an assignment",private:"This assignment is currently only visible to admins and moderators of this space. When you are ready for all space members to use it, change the general access setting above."},baseTemplate:{ide:{info:"The default RStudio template is applied to any project created in this space via the <em>New RStudio Project</em> action in the <em>New Project</em> menu.",label:"Make it the RStudio default"},jupyter:{info:"The default Jupyter template is applied to any project created in this space via the <em>New Jupyter Project</em> action in the <em>New Project</em> menu.",label:"Make it the Jupyter default"},label:"More info about default templates"},mode:{restrictions:"Note that a project can be either an assignment or a template, but not both."},special:"Special Access",template:{label:"Make this project a template",info:{access:"Templates are listed in the New Project from Template dialog, in the Your Content list and in the Templates list.",edit:"Go to the Info panel to edit a template's name, description and image.",label:"More info about templates",lede:"Want to use a project as a convenient starting point for future projects? Make it a template. New projects can then be created from the template and pick up its packages, files and resource settings."},private:"This template can only be accessed by admins and moderators of this space. When you are ready for all space members to use it, change the general access setting above."}},applyChanges:{applyChanges:"Apply Changes",confirmResourcesChange:"Change project resources",confirmBaseImageChange:"Change operating system",confirmChangeMessage:"To apply these changes, we will need to close and reopen the project.",confirmChangeOSMessage:"<p>To apply these changes, we will need to close and reopen the project.</p><p>After we reopen the project, we will automatically reinstall the project's R packages to be compatible with the new operating system. You will be able to view the progress in the Jobs pane.</p>",updating:"Updating project"},image:{title:"System Image",os:"Operating system",focal:"Ubuntu 20.04 (Focal)",noble:"Ubuntu 24.04 (Noble)",info:{description:"To ensure that each project executes securely and independently from all other projects, Posit Cloud deploys each project in its own container. The image determines the operating system and system packages that are installed in the container for your project.",label:"More info about system images"}},info:{description:{title:"Description",placeholder:"Click to enter project description"},details:"Details",nameAuthor:"Name & Author",outputs:{title:"Outputs",more:"view all {count}"},type:"Type"},label:"Project Settings",resources:{killTimeout:"Background Execution Limit",jupyterMessage:"This feature is not yet supported for Jupyter projects. Running Jupyter projects will execute in the background for approximately 24 hours before being shut down."}},error:{noProjectName:"Please enter a name for your project"},idle:"While you were away, your project went to sleep.",idleTempCopyWarning:"Your changes to this temporary copy may have been lost - save a permanent copy if you want to keep any changes you make.",type:{ide:"RStudio Project",jupyter:"Jupyter Project"}},task:{error:{retry:"There was a problem with the task, please try again. (Task {task_id})",technical:"Task {task_id} failed: {message}"}},trash:{message:{lede:"Content in the trash for 30 days or more will be permanently deleted.",access:"Content in the trash cannot be opened or edited.",restoration:"To restore content for viewing or editing, click the Restore button for that content - it will then reappear in your content listing.",emptying:"To permanently delete ALL c